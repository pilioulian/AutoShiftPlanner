<?xml version="1.0" encoding="UTF-8"?>

<solver xmlns="https://timefold.ai/xsd/solver" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://timefold.ai/xsd/solver https://timefold.ai/xsd/solver/solver.xsd">    <environmentMode>REPRODUCIBLE</environmentMode>

    <!-- Domain model configuration -->
    <solutionClass>org.betaiotazeta.autoshiftplanner.Solution</solutionClass>
    <entityClass>org.betaiotazeta.autoshiftplanner.ShiftAssignment</entityClass>

    <!-- Score configuration -->
    <!-- Migrated from AspEasyScoreCalculator to Constraint Streams (per-shift, feasibility-equivalent;
         see CONSTRAINTS.md). The legacy easy-score config is preserved in aspEasyScoreSolverConfig.xml.
         The move selectors below are score-director-agnostic and were kept verbatim from the tuned
         legacy config. -->
    <scoreDirectorFactory>
        <constraintProviderClass>org.betaiotazeta.autoshiftplanner.AspConstraintProvider</constraintProviderClass>
        <!-- BAVET (not the legacy Drools engine): Drools CS hits a groupBy reaccumulation bug during
             incremental solving on this model, and BAVET is the faster, supported implementation. -->
        <constraintStreamImplType>BAVET</constraintStreamImplType>
    </scoreDirectorFactory>

    <!-- Optimization algorithms configuration -->
    <termination>
        <secondsSpentLimit>180</secondsSpentLimit>
        <bestScoreLimit>0hard/0soft</bestScoreLimit>
    </termination>

    <!-- constructionHeuristic phase -->
    <constructionHeuristic>
        <cartesianProductMoveSelector>                
                <changeMoveSelector>
                    <filterClass>org.betaiotazeta.autoshiftplanner.ForbiddenCellSelectionFilter</filterClass>
                    <valueSelector variableName="timeGrain"/>
                </changeMoveSelector>
                <changeMoveSelector>
                    <valueSelector variableName="shiftDuration"/>
                </changeMoveSelector>
        </cartesianProductMoveSelector>
        <!-- <constructionHeuristicType>FIRST_FIT</constructionHeuristicType> -->
    </constructionHeuristic>

    <!-- localSearch phase -->
    <localSearch>                    
        <unionMoveSelector>
            <changeMoveSelector>
                 <filterClass>org.betaiotazeta.autoshiftplanner.ForbiddenCellSelectionFilter</filterClass>
            </changeMoveSelector>

            <swapMoveSelector>
            </swapMoveSelector>
            
            <pillarChangeMoveSelector>
                <valueSelector variableName="timeGrain"/>
            </pillarChangeMoveSelector>
            <pillarChangeMoveSelector>
                <valueSelector variableName="shiftDuration"/>
            </pillarChangeMoveSelector>

            <!--
            <pillarSwapMoveSelector>
            </pillarSwapMoveSelector>
            -->
            
            <cartesianProductMoveSelector>
                <changeMoveSelector>
                    <filterClass>org.betaiotazeta.autoshiftplanner.ForbiddenCellSelectionFilter</filterClass>                 
                </changeMoveSelector>
                <changeMoveSelector>
                    <filterClass>org.betaiotazeta.autoshiftplanner.ForbiddenCellSelectionFilter</filterClass>                 
                </changeMoveSelector>
            </cartesianProductMoveSelector>
            
        </unionMoveSelector>
    </localSearch>
      
</solver>