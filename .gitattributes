# Normalize line endings: store text as LF in the repo and check it out as LF
# everywhere (this repo lives on a WSL /mnt/c mount, where editors otherwise
# rewrite files as CRLF and produce whole-file "changes"). See CLAUDE.md.
* text eol=lf

# Binary assets — never apply text/eol conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
